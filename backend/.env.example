# ── LLM via 火山方舟 Agent Plan ───────────────────────────
# OpenAI 兼容接口: https://ark.cn-beijing.volces.com/api/plan/v3
# 支持模型: glm-5.2 (1M上下文,推理模型) / deepseek-chat / doubao-seed-2.0-pro 等
SILK_GATEWAY_URL=https://ark.cn-beijing.volces.com/api/plan/v3
SILK_GATEWAY_KEY=your_volcengine_ark_api_key
LLM_MODEL=glm-5.2

# ── Tencent Maps (腾讯位置服务) ───────────────────────────
# One key works for both WebService (backend) and JS API (frontend).
# Backend key: configure IP whitelist or SN in Tencent console.
QQ_MAP_KEY=TATBZ-EC3Y4-TIRUG-FNNCB-5XW7J-7EBBU
# Frontend JS API key (can be same as above, but configure domain whitelist)
QQ_MAP_JS_KEY=TATBZ-EC3Y4-TIRUG-FNNCB-5XW7J-7EBBU

# ── Weather (和风天气) ────────────────────────────────────
# https://dev.qweather.com
QWEATHER_KEY=

# ── Unsplash (scenic/food photos) ─────────────────────────
# https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# ── Database ──────────────────────────────────────────────
# Use SQLite for local dev (no Docker needed), PostgreSQL for production
DATABASE_URL=sqlite:///./offroadtrip.db
# DATABASE_URL=postgresql://offroadtrip:password@postgres:5432/offroadtrip

# ── App ───────────────────────────────────────────────────
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173
