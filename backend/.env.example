# ── LLM via 火山方舟 Agent Plan ───────────────────────────
SILK_GATEWAY_URL=https://ark.cn-beijing.volces.com/api/plan/v3
SILK_GATEWAY_KEY=your-volcengine-ark-api-key
LLM_MODEL=glm-5.2

# ── Tencent Maps (腾讯位置服务) ───────────────────────────
QQ_MAP_KEY=your-tencent-map-webservice-key
QQ_MAP_JS_KEY=your-tencent-map-js-key

# ── Weather (和风天气) ────────────────────────────────────
QWEATHER_KEY=

# ── Unsplash (scenic/food photos) ─────────────────────────
UNSPLASH_ACCESS_KEY=

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./offroadtrip.db

# ── App ───────────────────────────────────────────────────
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173
